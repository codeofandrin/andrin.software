{
  "name": "andrin.software",
  "description": "Personal website of Andrin Schaller",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "rm -r .next | next dev --webpack",
    "build": "rm -r .next | next build --webpack",
    "start": "next start",
    "format": "prettier --write --list-different .",
    "typecheck": "tsc --noEmit --noUnusedLocals --noUnusedParameters --composite false",
    "check": "npm run format && npm run typecheck",
    "bump": "npm version -m 'Bump version to %s' $npm_config_vers"
  },
  "dependencies": {
    "@react-email/components": "1.0.10",
    "@react-email/render": "2.0.4",
    "@svgr/webpack": "^8.1.0",
    "email-validator": "^2.0.4",
    "next": "^16.1.6",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "raw-loader": "^4.0.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "resend": "^6.9.3",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@react-email/preview-server": "5.2.10",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react-email": "5.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
